# .envrc for New_devs_App project
# This file is used by direnv to automatically load the Nix development environment

# Check if nix flakes are available
if ! has nix_direnv_version || ! nix_direnv_version 3.0.4; then
  source_url "https://raw.githubusercontent.com/nix-community/nix-direnv/3.0.4/direnvrc" "sha256-DzlYZ33mWF/Gs8DDeyjr8mnVmQGx7ASYqA5WlxwvBG4="
fi

# Use the flake
use flake

# Load any local .env file if it exists
dotenv_if_exists .env

# Watch for changes in key files to trigger reload
watch_file flake.nix
watch_file flake.lock
watch_file backend/pyproject.toml
watch_file frontend/package.json

# Set project root
export PROJECT_ROOT="$PWD"

# Helpful message
log_status "Base360 development environment loaded via Nix flake 🚀"
